-- ==================== Utility ====================
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title    = title,
            Text     = text,
            Duration = duration or 3,
        })
    end)
end

local function safeRead(tbl, ...)
    local cur = tbl
    for _, k in ipairs({...}) do
        if type(cur) ~= "table" and type(cur) ~= "userdata" then return nil end
        local ok, v = pcall(function() return cur[k] end)
        if not ok then return nil end
        cur = v
    end
    return cur
end

local function clampRange(v)
    return math.max(0.5, math.min(v or CFG.DEFAULT_PROXIMITY, 500))
end

local function normalizeAnimId(id)
    if not id then return "" end
    return tostring(id):gsub("rbxassetid://", ""):match("^%s*(.-)%s*$")
end

