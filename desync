-- ─── Config ───────────────────────────────────────────────────────────────────
local CONFIG = {
    range         = 4,          -- detection radius (studs)
    minRange      = 1,
    maxRange      = 15,
    dotThreshold  = 0.45,       -- how strictly "behind" means behind (0 = side-on, 1 = directly behind)
    tpOffset      = 0.4,        -- studs behind killer on teleport
    tpDuration    = 0.55,       -- seconds to keep teleporting
    lookDuration  = 0.65,       -- seconds to align look direction
    globalCooldown = 2.2,       -- seconds before re-triggering same killer
    daggerEvent   = {"Modules", "Network", "RemoteEvent"},
    killerNames   = {"Jason", "c00lkidd", "JohnDoe", "1x1x1x1", "Noli"},
    killersPath   = {"Players", "Killers"},
    modes         = {"Behind", "Around"},
}

-- ─── State ────────────────────────────────────────────────────────────────────
local state = {
    enabled    = false,
    mode       = "Behind",
    cooldowns  = {},   -- [killerName] = timestamp
    connection = nil,
}

-- ─── Resolve paths safely ─────────────────────────────────────────────────────
local function waitPath(root, ...)
    local node = root
    for _, name in ipairs({...}) do
        node = node:WaitForChild(name, 10)
        if not node then return nil end
    end
    return node
end

local daggerRemote  = waitPath(ReplicatedStorage, table.unpack(CONFIG.daggerEvent))
local killersFolder = waitPath(workspace, table.unpack(CONFIG.killersPath))

if not daggerRemote or not killersFolder then
    warn("[BackstabPro] Failed to find required paths – aborting.")
    return
end

-- ─── Helpers ──────────────────────────────────────────────────────────────────
local function getChar()
    local char = lp.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        return char, char.HumanoidRootPart
    end
end

local function isOnCooldown(name)
    local t = state.cooldowns[name]
    return t and (tick() - t) < CONFIG.globalCooldown
end

local function setCooldown(name)
    state.cooldowns[name] = tick()
end

local function isBehind(hrp, targetHRP)
    local diff = hrp.Position - targetHRP.Position
    if diff.Magnitude > CONFIG.range then return false end
    if state.mode == "Around" then return true end
    -- dot product: positive = behind the killer's look direction
    return diff:Dot(-targetHRP.CFrame.LookVector) > CONFIG.dotThreshold
end

-- Safe teleport: only move if character and target still exist
local function safeTeleport(hrp, targetHRP)
    if not (hrp and hrp.Parent and targetHRP and targetHRP.Parent) then return false end
    local behindPos = targetHRP.Position - (targetHRP.CFrame.LookVector * CONFIG.tpOffset)
    hrp.CFrame = CFrame.new(behindPos, behindPos + targetHRP.CFrame.LookVector)
    return true
end

-- ─── Core backstab routine ────────────────────────────────────────────────────
local function performBackstab(killer)
    local name = killer.Name
    setCooldown(name)

    local char, hrp = getChar()
    if not char then return end

    local kHRP = killer:FindFirstChild("HumanoidRootPart")
    if not kHRP then return end

    local startTime = tick()
    local daggerFired = false
    local tpConn, lookConn

    -- Phase 1: constant TP behind killer
    tpConn = RunService.Heartbeat:Connect(function()
        local char2, hrp2 = getChar()
        if not char2 or (tick() - startTime) >= CONFIG.tpDuration then
            tpConn:Disconnect()
            return
        end
        safeTeleport(hrp2, kHRP)

        if not daggerFired then
            daggerFired = true

            -- Phase 2: align look direction
            local lookStart = tick()
            lookConn = RunService.Heartbeat:Connect(function()
                local _, hrp3 = getChar()
                if not hrp3 or not kHRP.Parent or (tick() - lookStart) >= CONFIG.lookDuration then
                    if lookConn then lookConn:Disconnect() end
                    return
                end
                hrp3.CFrame = CFrame.new(hrp3.Position, hrp3.Position + kHRP.CFrame.LookVector)
            end)

            -- Fire dagger
            daggerRemote:FireServer("UseActorAbility", "Dagger")
        end
    end)

    -- Phase 3: reset cooldown after leaving range
    task.spawn(function()
        task.wait(CONFIG.globalCooldown)
        local _, hrp2 = getChar()
        if hrp2 and kHRP.Parent then
            local waited = 0
            while isBehind(hrp2, kHRP) and waited < 10 do
                RunService.Heartbeat:Wait()
                waited += 1
                _, hrp2 = getChar()
                if not hrp2 then break end
            end
        end
        -- cooldown already recorded by timestamp; no extra flag needed
    end)
end

-- ─── Main loop ────────────────────────────────────────────────────────────────
local function startLoop()
    if state.connection then state.connection:Disconnect() end

    state.connection = RunService.Heartbeat:Connect(function()
        if not state.enabled then return end

        local char, hrp = getChar()
        if not char then return end

        for _, name in ipairs(CONFIG.killerNames) do
            if not isOnCooldown(name) then
                local killer = killersFolder:FindFirstChild(name)
                if killer and killer:FindFirstChild("HumanoidRootPart") then
                    if isBehind(hrp, killer.HumanoidRootPart) then
                        task.spawn(performBackstab, killer)
                        break  -- one backstab per frame
                    end
                end
            end
        end
    end)
end

startLoop()

