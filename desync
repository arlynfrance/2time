-- ── Helper to make a styled button ─────────────────────────────────────────
local function makeButton(text, posY, color)
    local btn = Instance.new("TextButton")
    btn.Size              = UDim2.new(1, -20, 0, 30)
    btn.Position          = UDim2.new(0, 10, 0, posY)
    btn.BackgroundColor3  = color or Color3.fromRGB(28, 28, 35)
    btn.BorderSizePixel   = 0
    btn.TextColor3        = Color3.fromRGB(230, 230, 230)
    btn.Font              = Enum.Font.GothamSemibold
    btn.TextSize          = 13
    btn.Text              = text
    btn.AutoButtonColor   = false
    btn.Parent            = panel
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 6)
    c.Parent = btn

    -- Hover tween
    local hoverIn  = TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(45, 45, 58)})
    local hoverOut = TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = color or Color3.fromRGB(28, 28, 35)})
    btn.MouseEnter:Connect(function() hoverIn:Play() end)
    btn.MouseLeave:Connect(function() hoverOut:Play() end)

    return btn
end

-- ── Helper to make a labelled TextBox ───────────────────────────────────────
local function makeInput(labelText, placeholder, defaultVal, posY)
    local lbl = Instance.new("TextLabel")
    lbl.Size                = UDim2.new(1, -20, 0, 16)
    lbl.Position            = UDim2.new(0, 10, 0, posY)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3          = Color3.fromRGB(160, 160, 175)
    lbl.Font                = Enum.Font.Gotham
    lbl.TextSize            = 11
    lbl.Text                = labelText
    lbl.TextXAlignment      = Enum.TextXAlignment.Left
    lbl.Parent              = panel

    local box = Instance.new("TextBox")
    box.Size                = UDim2.new(1, -20, 0, 26)
    box.Position            = UDim2.new(0, 10, 0, posY + 17)
    box.BackgroundColor3    = Color3.fromRGB(22, 22, 30)
    box.BorderSizePixel     = 0
    box.TextColor3          = Color3.fromRGB(230, 230, 230)
    box.Font                = Enum.Font.Gotham
    box.TextSize            = 13
    box.PlaceholderText     = placeholder
    box.Text                = tostring(defaultVal)
    box.ClearTextOnFocus    = false
    box.Parent              = panel
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 5)
    c.Parent = box

    return box
end

