-- ==================== Main Backstab Watcher ====================
task.spawn(function()
    while true do
        task.wait(CFG.CHECK_INTERVAL)
        if not State.enabled then continue end

        local range  = clampRange(CFG.DEFAULT_PROXIMITY)
        local folder = getKillersFolder()
        if not folder then continue end

        local char = getCharacter()
        local hrp  = getHRP(char)
        if not hrp then continue end

        local now = os.clock()
        if now - State.lastBackstabTime < CFG.COOLDOWN then continue end

        for _, killer in ipairs(folder:GetChildren()) do
            if not isValidKiller(killer) then continue end
            local khrp = killer:FindFirstChild("HumanoidRootPart")
            if not khrp then continue end

            local dist     = (khrp.Position - hrp.Position).Magnitude
            local trigger  = false

            if CFG.RANGE_MODE == "Around" then
                trigger = dist <= range
            else
                -- Behind mode
                local rel        = hrp.Position - khrp.Position
                local forwardDot = rel:Dot(khrp.CFrame.LookVector)
                local behindDist = -forwardDot
                local angleDot   = rel.Magnitude > 0 and rel.Unit:Dot(khrp.CFrame.LookVector) or 0

                local passedDot  = CFG.DIRECT_BEHIND and (angleDot <= -0.85) or (forwardDot < 0.3)
                trigger = passedDot and behindDist <= range and dist <= range and isPlayerCharacter(killer)
            end

            if trigger and isDaggerReady() then
                State.lastBackstabTime = now
                local daggerbtn = getDaggerButton()
                task.spawn(function()
                    activateForKiller(killer, CFG.DEFAULT_DURATION)
                    if State.daggerEnabled then
                        task.wait(CFG.DELAY_BEFORE_STAB)
                        tryActivateButton(daggerbtn)
                    end
                end)
                break  -- only trigger for one killer per cycle
            end
        end
    end
end)

-- ==================== GlideStab Watcher ====================
task.spawn(function()
    while true do
        task.wait(CFG.GLIDESTAB_CHECK_RATE)
        if not CFG.GLIDESTAB_ENABLED then continue end
        if os.clock() - State.lastGlidestabTime < CFG.GLIDESTAB_COOLDOWN then continue end

        local char = getCharacter()
        local hrp  = getHRP(char)
        if not hrp then continue end
        if not isPlayingTargetAnim(char) then continue end

        local folder = getKillersFolder()
        if not folder then continue end

        local range     = clampRange(CFG.DEFAULT_PROXIMITY)
        local candidate = nil

        for _, killer in ipairs(folder:GetChildren()) do
            if not isValidKiller(killer) then continue end
            local khrp = killer:FindFirstChild("HumanoidRootPart")
            if not khrp then continue end

            local dist = (khrp.Position - hrp.Position).Magnitude
            if dist > range then continue end

            -- wait up to timeout for player to arrive beside killer
            local t0      = os.clock()
            local timeout = CFG.GLIDESTAB_BESIDE_TIMEOUT or 1
            while os.clock() - t0 < timeout do
                if isBesideKiller(hrp, khrp, range) then
                    candidate = killer; break
                end
                task.wait(0.05)
            end
            if candidate then break end
        end

        if not candidate then continue end

        local khrp      = candidate:FindFirstChild("HumanoidRootPart")
        if not khrp then continue end

        local daggerbtn = getDaggerButton()
        local mode      = CFG.AIMING_MODE
        local cam       = Workspace.CurrentCamera
        local prevCamCF = (mode == "Camera" and cam) and cam.CFrame or nil
        local releaseAim= (mode == "Character") and acquireAimLock() or function() end

        State.lastGlidestabTime = os.clock()
        local endTime = os.clock() + (CFG.GLIDESTAB_DURATION or 0.4)

        if CFG.GLIDESTAB_TYPE == "Teleport" then
            while os.clock() < endTime do
                if not hrp or not khrp then break end
                local fwd   = khrp.CFrame.LookVector.Unit
                local bDist = tonumber(CFG.BEHIND_DISTANCE) or 1.7
                local bPos  = khrp.Position - fwd * bDist
                local tPos  = Vector3.new(bPos.X, hrp.Position.Y, bPos.Z)
                pcall(function() hrp.CFrame = CFrame.new(tPos, tPos + fwd) end)
                pcall(function() tryActivateButton(daggerbtn) end)
                task.wait(0.03)
            end
        else
            -- Legit: aim at killer while beside them
            while os.clock() < endTime do
                if not hrp or not khrp then break end
                if not isBesideKiller(hrp, khrp, range) then break end

                if mode == "Character" then
                    pcall(function()
                        local p = hrp.Position
                        hrp.CFrame = CFrame.new(p, Vector3.new(khrp.Position.X, p.Y, khrp.Position.Z))
                    end)
                elseif mode == "Camera" and cam then
                    pcall(function()
                        cam.CFrame = CFrame.new(cam.CFrame.Position, khrp.Position)
                    end)
                end

                pcall(function() tryActivateButton(daggerbtn) end)
                task.wait(0.06)
            end
        end

        releaseAim()
        if mode == "Camera" and prevCamCF and Workspace.CurrentCamera then
            pcall(function() Workspace.CurrentCamera.CFrame = prevCamCF end)
        end
    end
end)

-- ==================== GlideStab Assist Watcher ====================
task.spawn(function()
    while true do
        task.wait(CFG.ASSIST_CHECK_RATE)

        if not CFG.ASSIST_ENABLED then
            State.assistPrevPlaying = false
            continue
        end

        local char = getCharacter()
        if not char then State.assistPrevPlaying = false; continue end

        local playing = isPlayingTargetAnim(char)

        -- Only trigger on rising edge (animation just started)
        if playing and not State.assistPrevPlaying then
            local folder = getKillersFolder()
            if folder then
                local hrp       = getHRP(char)
                local candidate = nil

                local ok, res = pcall(findCandidateKillerForAssist, folder, hrp, math.huge)
                if ok and res then
                    candidate = res
                else
                    -- fallback: first valid killer
                    for _, k in ipairs(folder:GetChildren()) do
                        if isValidKiller(k) then candidate = k; break end
                    end
                end

                if candidate then
                    task.spawn(function()
                        pcall(doGlidestabAssist, candidate)
                    end)
                end
            end
        end

        State.assistPrevPlaying = playing
    end
end)
