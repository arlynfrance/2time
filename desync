-- ==================== Aiming helpers ====================
local function setAutoRotate(value)
    local hum = getHumanoid()
    if hum then pcall(function() hum.AutoRotate = value end) end
end

-- Thread-safe ref-counted aiming lock.
-- Returns a cleanup function that MUST be called exactly once.
local function acquireAimLock()
    if not CFG.AIMING_ENABLED then return function() end end
    State.aimRefCount += 1
    if State.aimRefCount == 1 then setAutoRotate(false) end
    local released = false
    return function()
        if released then return end
        released = true
        State.aimRefCount = math.max(0, State.aimRefCount - 1)
        if State.aimRefCount == 0 then setAutoRotate(true) end
    end
end

-- ==================== Killer folder helpers ====================
local function getKillersFolder()
    local wPlayers = Workspace:FindFirstChild("Players")
    return wPlayers and wPlayers:FindFirstChild("Killers")
end

local function isValidKiller(model)
    if not model or not model:IsA("Model") then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local hum = model:FindFirstChildWhichIsA("Humanoid")
    return hrp ~= nil and hum ~= nil and (hum.Health or 0) > 0
end

local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    if not model:FindFirstChildWhichIsA("Humanoid") then return false end
    return Players:GetPlayerFromCharacter(model) ~= nil
end

-- ==================== Dagger UI helpers ====================
local function getDaggerButton()
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local mainUI = pg:FindFirstChild("MainUI")
    if not mainUI then return nil end
    local container = mainUI:FindFirstChild("AbilityContainer")
    if not container then return nil end
    return container:FindFirstChild("Dagger")
end

local function getDaggerCooldownValue()
    local btn = getDaggerButton()
    if not btn then return nil end
    -- try common child names/types in priority order
    for _, name in ipairs({"CooldownTime","Cooldown","CooldownLabel","Timer","CD"}) do
        local child = btn:FindFirstChild(name)
        if child then
            if child:IsA("NumberValue") then return child.Value end
            if child:IsA("StringValue") then return tonumber(child.Value) end
            if child:IsA("TextLabel") or child:IsA("TextBox") then return tonumber(child.Text) end
        end
    end
    -- fallback: any NumberValue or StringValue child
    local nv = btn:FindFirstChildWhichIsA("NumberValue")
    if nv then return nv.Value end
    local sv = btn:FindFirstChildWhichIsA("StringValue")
    if sv then return tonumber(sv.Value) end
    return nil
end

local function isDaggerReady()
    local cd = getDaggerCooldownValue()
    return not (cd and cd > 0.1)
end

local function tryActivateButton(btn)
    if not btn then return false end
    pcall(function() btn:Activate() end)

    -- fire any MouseButton1Click connections via getconnections if available
    pcall(function()
        if type(getconnections) ~= "function" then return end
        local ok2, conns = pcall(getconnections, btn.MouseButton1Click)
        if not ok2 or not conns then return end
        for _, conn in ipairs(conns) do
            pcall(function()
                if conn.Function then conn.Function()
                elseif conn.func    then conn.func()
                elseif conn.Fire    then conn.Fire()
                end
            end)
        end
    end)

    -- also fire Activated signal if it exists
    pcall(function()
        local sig = rawget(btn, "Activated")
        if sig and sig.Fire then sig:Fire() end
    end)

    return true
end

-- ==================== Killer velocity tracker ====================
-- Keyed by killer model (not HRP part) to survive part refreshes.
RunService.Heartbeat:Connect(function(dt)
    local folder = getKillersFolder()
    if not folder then return end
    local now = os.clock()

    for _, killer in ipairs(folder:GetChildren()) do
        if not isValidKiller(killer) then continue end
        local khrp = killer:FindFirstChild("HumanoidRootPart")
        if not khrp then continue end

        local pos  = khrp.Position
        local look = khrp.CFrame.LookVector
        local prev = State.killerVelocity[killer]

        if prev and prev.t then
            local elapsed = now - prev.t
            if elapsed > 0 then
                local rawVel = (pos - prev.pos) / elapsed
                -- exponential smoothing
                local alpha   = math.clamp(elapsed * 10, 0, 1)
                local smoothV = prev.vel and prev.vel:Lerp(rawVel, alpha) or rawVel
                State.killerVelocity[killer] = {
                    pos = pos, vel = smoothV, look = look,
                    prevLook = prev.look, t = now,
                }
            end
        else
            State.killerVelocity[killer] = {
                pos = pos, vel = Vector3.zero, look = look,
                prevLook = look, t = now,
            }
        end
    end

    -- purge stale entries (killer removed from folder)
    for killer in pairs(State.killerVelocity) do
        if not killer.Parent or killer.Parent ~= folder then
            State.killerVelocity[killer] = nil
        end
    end
end)

-- ==================== Velocity / Prediction helpers ====================
local function getKillerVelocity(killer)
    local tracked = State.killerVelocity[killer]
    if tracked and tracked.vel then return tracked.vel end
    -- fallback: AssemblyLinearVelocity (safe, non-deprecated)
    local khrp = killer and killer:FindFirstChild("HumanoidRootPart")
    if khrp then
        local ok, v = pcall(function() return khrp.AssemblyLinearVelocity end)
        if ok and v then return v end
    end
    return Vector3.zero
end

local function computeBehindCFrame(killer, selfHRP)
    local khrp = killer:FindFirstChild("HumanoidRootPart")
    if not khrp or not selfHRP then return nil end

    local kCF   = khrp.CFrame
    local fwd   = kCF.LookVector.Unit
    local bDist = tonumber(CFG.BEHIND_DISTANCE) or 1.7
    local base  = khrp.Position - fwd * bDist
    base = Vector3.new(base.X, khrp.Position.Y, base.Z)

    if not CFG.PREDICTION_ENABLED then
        return CFrame.new(base, base + fwd)
    end

    local vel    = getKillerVelocity(killer)
    local horiz  = Vector3.new(vel.X, 0, vel.Z)
    local dt_p   = CFG.PREDICTION_TIME   or 0.12
    local str    = CFG.PREDICTION_STRENGTH or 0.6
    local move   = horiz * dt_p * str

    local right  = kCF.RightVector
    local fwdC   = fwd   * move:Dot(fwd)
    local latC   = right * move:Dot(right)

    -- turn compensation
    local turnC  = Vector3.zero
    local tracked = State.killerVelocity[killer]
    if tracked and tracked.prevLook then
        local dLook    = fwd - tracked.prevLook
        local turnAmt  = dLook:Dot(right)
        turnC = right * (turnAmt * 3.0 * str)
    end

    local offset = fwdC + latC + turnC
    local final  = base + Vector3.new(offset.X, 0, offset.Z)
    return CFrame.new(final, final + fwd)
end

-- ==================== Main backstab activator ====================
local function activateForKiller(killer, duration)
    if not killer then return end
    local char = getCharacter()
    local hrp  = getHRP(char)
    if not hrp then return end

    duration = duration or CFG.DEFAULT_DURATION
    local releaseAim = acquireAimLock()

    if not CFG.AIMING_ENABLED then
        task.delay(duration, releaseAim)
        return
    end

    if hrp.Anchored then
        pcall(function() hrp.Anchored = false end)
    end

    local btype = CFG.BACKSTAB_TYPE

    if btype == "lerp" then
        -- initial tween snap
        local goal = computeBehindCFrame(killer, hrp)
        if goal then
            local ok, tween = pcall(function()
                return TweenService:Create(hrp, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = goal})
            end)
            if ok and tween then pcall(function() tween:Play() end) end
        end

        local t0   = os.clock()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock() - t0 >= duration then
                conn:Disconnect(); releaseAim(); return
            end
            local khrp = killer:FindFirstChild("HumanoidRootPart")
            if not khrp or not hrp then
                conn:Disconnect(); releaseAim(); return
            end
            local target = computeBehindCFrame(killer, hrp)
            if target then
                -- exponential lerp: framerate-independent
                local alpha = 1 - (1 - CFG.LERP_SPEED) ^ (RunService.Heartbeat:Wait() * 60 + 1)
                -- simpler fallback: just use fixed alpha
                pcall(function() hrp.CFrame = hrp.CFrame:Lerp(target, CFG.LERP_SPEED) end)
            end
        end)

    elseif btype == "teleport" then
        local t0   = os.clock()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock() - t0 >= duration then
                conn:Disconnect(); releaseAim(); return
            end
            local target = computeBehindCFrame(killer, hrp)
            if target then pcall(function() hrp.CFrame = target end) end
        end)

    else
        -- "just auto stab (if its on)" - only rotate to face same direction
        local t0   = os.clock()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock() - t0 >= duration then
                conn:Disconnect(); releaseAim(); return
            end
            local khrp = killer:FindFirstChild("HumanoidRootPart")
            if not khrp then return end
            local lookVec = khrp.CFrame.LookVector
            local curPos  = hrp.Position
            pcall(function() hrp.CFrame = CFrame.new(curPos, curPos + lookVec) end)
        end)
    end
end

-- ==================== Animation detection ====================
local function isPlayingTargetAnim(char)
    if not char then return false end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if not hum then return false end

    local ok, tracks = pcall(function() return hum:GetPlayingAnimationTracks() end)
    if not ok or not tracks then return false end

    local target = normalizeAnimId(CFG.TARGET_ANIM_ID)
    for _, track in ipairs(tracks) do
        local anim = track and track.Animation
        if anim and anim.AnimationId then
            if normalizeAnimId(anim.AnimationId) == target then
                return true
            end
        end
    end
    return false
end

-- ==================== GlideStab side-check ====================
local function isBesideKiller(hrp, khrp, range)
    if not hrp or not khrp then return false end
    local rel  = hrp.Position - khrp.Position
    local flat = Vector3.new(rel.X, 0, rel.Z)
    if flat.Magnitude > range then return false end
    if flat.Magnitude <= 0 then return false end
    local sideDot = math.abs(flat.Unit:Dot(khrp.CFrame.RightVector))
    return sideDot >= 0.9
end

local function findCandidateKillerForAssist(killersFolder, hrp, range)
    if not killersFolder or not hrp then return nil end
    range = range or math.huge
    local nearest, nearestDist = nil, math.huge
    for _, k in ipairs(killersFolder:GetChildren()) do
        if isValidKiller(k) then
            local khrp = k:FindFirstChild("HumanoidRootPart")
            if khrp then
                local dist = (khrp.Position - hrp.Position).Magnitude
                if dist <= range then
                    if isBesideKiller(hrp, khrp, range) then return k end
                    if dist < nearestDist then nearest = k; nearestDist = dist end
                end
            end
        end
    end
    return nearest
end

-- ==================== GlideStab Assist ====================
local function doGlidestabAssist(killer)
    if not killer then return end
    local char     = getCharacter()
    local hrp      = getHRP(char)
    local khrp     = killer:FindFirstChild("HumanoidRootPart")
    if not hrp or not khrp then return end

    local SIDE_DIST = 6
    local mode      = CFG.AIMING_MODE
    local cam       = Workspace.CurrentCamera
    local prevCamCF = (mode == "Camera" and cam) and cam.CFrame or nil

    local releaseAim = (mode == "Character") and acquireAimLock() or function() end

    -- already beside — nothing to do
    if isBesideKiller(hrp, khrp, CFG.DEFAULT_PROXIMITY) then
        releaseAim(); return
    end

    local t0       = os.clock()
    local duration = CFG.ASSIST_DURATION  or 0.5
    local tickRate = CFG.ASSIST_CHECK_RATE or 0.03

    while os.clock() - t0 < duration do
        if not hrp or not khrp then break end
        if isBesideKiller(hrp, khrp, CFG.DEFAULT_PROXIMITY) then break end

        local rel      = hrp.Position - khrp.Position
        local sideDot  = rel:Dot(khrp.CFrame.RightVector)
        local sideSign = sideDot >= 0 and 1 or -1

        local predictedPos = khrp.Position
        if CFG.PREDICTION_ENABLED then
            local vel   = getKillerVelocity(killer)
            local horiz = Vector3.new(vel.X, 0, vel.Z)
            predictedPos = predictedPos + horiz * (CFG.PREDICTION_TIME or 0.12) * (CFG.PREDICTION_STRENGTH or 0.6)
        end

        local sidePoint = predictedPos + khrp.CFrame.RightVector * sideSign * SIDE_DIST

        if mode == "Character" then
            pcall(function()
                local p = hrp.Position
                hrp.CFrame = CFrame.new(p, Vector3.new(sidePoint.X, p.Y, sidePoint.Z))
            end)
        elseif mode == "Camera" and cam then
            pcall(function()
                cam.CFrame = CFrame.new(cam.CFrame.Position, sidePoint)
            end)
        end

        task.wait(tickRate)
    end

    releaseAim()
    if mode == "Camera" and prevCamCF and Workspace.CurrentCamera then
        pcall(function() Workspace.CurrentCamera.CFrame = prevCamCF end)
    end
end

-- ==================== Custom Anim injection ====================
local function applyAnimsToModule(mod)
    mod.Animations = mod.Animations or {}
    for _, k in ipairs(animKeys) do
        local v = TwoTimeAnimInputs[k]
        if v and tostring(v) ~= "" then
            mod.Animations[k] = tostring(v)
        end
    end
end

local function restoreAnims()
    local ok, mod = tryRequireTwoTime()
    if not ok then return false, mod end
    pcall(function()
        mod.Animations = mod.Animations or {}
        for _, k in ipairs(animKeys) do
            local orig = initialModuleAnims[k]
            mod.Animations[k] = (orig and orig ~= "") and orig or nil
        end
    end)
    return true
end

local function startInjectLoop()
    State.injectLoop = true
    task.spawn(function()
        while State.injectLoop and CFG.INJECT_ANIMS_ENABLED do
            local ok, mod = tryRequireTwoTime()
            if ok then pcall(applyAnimsToModule, mod) end
            task.wait(1)
        end
    end)
end

