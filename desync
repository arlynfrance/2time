local function findTwoTimeConfig()
    local ok, found = pcall(function()
        return ReplicatedStorage:FindFirstChild("Assets")
            and ReplicatedStorage.Assets:FindFirstChild("Survivors")
            and ReplicatedStorage.Assets.Survivors:FindFirstChild("TwoTime")
            and ReplicatedStorage.Assets.Survivors.TwoTime:FindFirstChild("Config")
    end)
    return (ok and found) or nil
end

local TwoTimePath = findTwoTimeConfig()

local function tryRequireTwoTime()
    if not TwoTimePath then TwoTimePath = findTwoTimeConfig() end
    if not TwoTimePath then return false, "module not found" end
    local ok, mod = pcall(require, TwoTimePath)
    if not ok then return false, mod end
    if type(mod) ~= "table" then return false, "module is not a table" end
    return true, mod
end

